{
  "compilerOptions": {
    "target": "ES2022", "lib": ["dom", "esnext"], "module": "esnext",
    "moduleResolution": "bundler", "jsx": "preserve", "strict": true,
    "esModuleInterop": true, "skipLibCheck": true, "incremental": true,
    "plugins": [{ "name": "next" }]
  },
  "include": ["**/*.ts", "**/*.tsx", ".next/types/**/*.ts"]
}
